output/             # Ignore the output directory where generated reports are stored
*.o                 # Ignore object files
*.out               # Ignore compiled output files
*.log               # Ignore log files
*.txt               # Ignore text files
.DS_Store           # Ignore macOS specific file
Thumbs.db           # Ignore Windows specific file
desktop.ini         # Ignore Windows specific file
.vscode/            # Ignore VSCode settings directory
*.swp               # Ignore Vim swap files